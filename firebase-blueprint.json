{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user information, details and screen-level permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "function": { "type": "string" },
        "birthDate": { "type": "string" },
        "address": { "type": "string" },
        "addressNumber": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "cep": { "type": "string" },
        "role": { 
          "type": "string",
          "enum": ["admin", "member"]
        },
        "permissions": {
          "type": "object",
          "description": "Map of screen IDs to booleans"
        },
        "isPending": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "BlockEntry": {
      "title": "Block Entry",
      "description": "Records the entry of marble/granite blocks into production.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "blockId": { "type": "string" },
        "type": { "type": "string" },
        "length": { "type": "number" },
        "height": { "type": "number" },
        "width": { "type": "number" },
        "volume": { "type": "number" },
        "entryDate": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blockId", "type", "length", "height", "width", "volume", "entryDate", "userId"]
    },
    "MaterialType": {
      "title": "Material Type",
      "description": "Registered material types for blocks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "SlabEntry": {
      "title": "Slab Entry",
      "description": "Records the result of sawing a block into slabs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "parentBlockId": { "type": "string" },
        "slabId": { "type": "string" },
        "length": { "type": "number" },
        "height": { "type": "number" },
        "area": { "type": "number" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["parentBlockId", "slabId", "length", "height", "area", "userId"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records important system events for security auditing.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "event": { "type": "string" },
        "details": { "type": "string" },
        "targetUserId": { "type": "string" },
        "targetUserName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { 
          "type": "string", 
          "enum": ["login_success", "login_failure", "user_create", "user_update", "user_delete", "security_access", "user_auth_change", "update", "upload"] 
        }
      },
      "required": ["event", "timestamp", "type"]
    },
    "Client": {
      "title": "Client",
      "description": "Store client information for sales/outlets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "document": { "type": "string", "description": "CPF or CNPJ" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "SlabOutlet": {
      "title": "Slab Outlet",
      "description": "Records the output (sale) of slabs to a client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "slabIds": { "type": "array", "items": { "type": "string" } },
        "totalM2": { "type": "number" },
        "totalItems": { "type": "integer" },
        "outletDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "slabIds", "totalM2", "outletDate", "userId"]
    },
    "AppSetting": {
      "title": "App Setting",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "appName": { "type": "string", "default": "MarmoControl" },
        "logoUrl": { "type": "string" },
        "logoSize": { "type": "number", "default": 24 },
        "loginLogoUrl": { "type": "string" },
        "loginLogoSize": { "type": "number", "default": 48 },
        "loginWelcomeTitle": { "type": "string", "default": "Entre na sua conta" },
        "loginWelcomeSubtitle": { "type": "string", "default": "Sistema de gestão inteligente para marmorarias." },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "AppSetting",
      "description": "Global application configuration documents."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    },
    "/blockEntries/{entryId}": {
      "schema": "BlockEntry",
      "description": "History of block entries."
    },
    "/materialTypes/{typeId}": {
      "schema": "MaterialType",
      "description": "List of available material types."
    },
    "/slabEntries/{slabId}": {
      "schema": "SlabEntry",
      "description": "History of slab entries (serragem)."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Registered clients."
    },
    "/slabOutlets/{outletId}": {
      "schema": "SlabOutlet",
      "description": "History of slab outputs/sales."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs."
    }
  }
}
